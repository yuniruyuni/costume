{
  "name": "costume.yuniruyuni.net",
  "peerDependencies": {
    "typescript": "^5.9.3",
    "bun-bagel": "^1.1.0",
    "clsx": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "1.8.3",
    "@happy-dom/global-registrator": "^16.8.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/bun": "^1.3.2",
    "@types/node": "^20.19.25",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "@types/web": "^0.0.294",
    "bun": "^1.3.2",
    "npm-run-all2": "^6.2.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "start": "run-p 'start:**'",
    "start:backend": "bun run --watch bin/local.ts",
    "start:frontend:html": "mkdir -p static && bun run bin/html.ts",
    "start:frontend:image": "mkdir -p static && bun run bin/image.ts",
    "start:frontend:favicon": "mkdir -p static && cp favicon.ico static/favicon.ico",
    "start:frontend:bundle": "bun build --hot --watch --sourcemap=inline --outdir=static/ src/index.tsx",
    "start:frontend:tailwind": "tailwindcss --hot --watch -o static/index.css -i src/index.css",
    "start:test": "bun --watch test",
    "start:type": "tsc --noEmit --watch",
    "start:lint": "bun run lint",
    "build": "run-s build:frontend",
    "build:frontend": "run-p 'build:frontend:**'",
    "build:frontend:html": "mkdir -p static && bun run bin/html.ts",
    "build:frontend:image": "mkdir -p static && bun run bin/image.ts",
    "build:frontend:favicon": "mkdir -p static && cp favicon.ico static/favicon.ico",
    "build:frontend:bundle": "NODE_ENV=production bun build --minify --outdir=./static/ src/index.tsx",
    "build:frontend:tailwind": "tailwindcss -i src/index.css -o ./static/index.css",
    "test": "bun test",
    "type": "tsc --noEmit",
    "lint": "biome lint",
    "format": "biome format --write",
    "check": "biome check --write"
  },
  "trustedDependencies": ["@biomejs/biome", "bun"],
  "dependencies": {
    "@tailwindcss/cli": "^4.1.17",
    "react-use": "^17.6.0",
    "wouter": "^3.7.1"
  }
}
